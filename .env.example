# Copy to .env and fill in. Never commit .env.

# Resend API (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender. Use onboarding@resend.dev until you verify a domain in Resend.
DIGEST_FROM=onboarding@resend.dev

# Recipient for both digests.
DIGEST_TO=TSheehy@Dollar-Flowers.com

# Distress threshold in whole USD. Default 2000000.
DISTRESS_MIN_USD=2000000
